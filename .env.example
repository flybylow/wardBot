# Combell mailbox — authenticate as ward@tabulas.eu, send as wardbot alias
IMAP_HOST=imap.mailprotect.be
IMAP_PORT=993
IMAP_USER=ward@tabulas.eu
IMAP_PASS=

SMTP_HOST=smtp-auth.mailprotect.be
SMTP_PORT=465
SMTP_USER=ward@tabulas.eu
SMTP_PASS=

BOT_ADDRESS=wardbot@tabulas.eu
MAIL_FROM_NAME=WardBot

# Auto-reply loop (npm start)
DRY_RUN=true
POLL_INTERVAL_MS=120000

# Mail UI live send (npm run dev) — allowed on 127.0.0.1 by default; set false to block
# ALLOW_SEND=false

# Local mail UI (npm run dev)
MAIL_UI_HOST=127.0.0.1
MAIL_UI_PORT=3456
MAIL_POLL_INTERVAL_MS=30000
EXPLORER_URL=http://localhost:3001
WARDBOT_URL=http://127.0.0.1:3456

ANTHROPIC_API_KEY=
